MONGO_URI=mongodb://localhost:27017/restaurantes_db
PORT=3000
NODE_ENV=development

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=RestuaranteRR
JWT_AUDIENCE=RestuaranteRRUsers
JWT_EXPIRES_IN=60m

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM="Los Rubios Rojos" <no-reply@losrubiosrojos.com>

FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

SEED_ADMIN_USERNAME=adminrestaurante
SEED_ADMIN_EMAIL=adminrestaurante@example.com
SEED_ADMIN_PASSWORD=replace-with-strong-password
SEED_ADMIN_ROLE=ADMIN
